---
pagination:
  data: gallery
  size: 24
  alias: galleryPage
permalink: "/gallery/{% if pagination.pageNumber > 0 %}{{ pagination.pageNumber + 1 }}/{% endif %}index.html"
date_updated: "2026-03-14"
---

{% extends "layouts/home.html" %}
{% set pageHeaderTitle = "Gallery" %}

{% block content %}
  {% include "partials/page-header.html" %}

  <article>
    <div class="[ wrapper ] [ flow ]">
      <div class="photo-gallery">
        {# for item in galleryPage | sort(attribute="date") | reverse #}
        {% for item in galleryPage %}
          <button
            class="gallery-card"
            type="button"
            aria-label="Open image: {{ item.alt }}"
            data-filename="{{ item.filename }}"
            data-full="{{ item.src }}"
            data-alt="{{ item.alt }}"
            data-caption="{{ item.caption | escape }}"
            data-date="{{ item.dateDisplay | escape }}"
            data-location="{{ item.location | escape }}"
          >
          <small>{{ item.filename }}</small>
            <img
              src="{{ item.thumb }}"
              alt="{{ item.alt }}"
              loading="lazy"
              decoding="async"
              {% if item.width %}width="{{ item.width }}"{% endif %}
              {% if item.height %}height="{{ item.height }}"{% endif %}
            >
          </button>
        {% endfor %}
      </div>
    </div>
  </article>

  <div class="lightbox" id="lightbox" hidden>
    <button class="lightbox__close" id="lightboxClose" aria-label="Close image">×</button>
    <button class="lightbox__nav lightbox__nav--prev" id="lightboxPrev" aria-label="Previous image">‹</button>
    <button class="lightbox__nav lightbox__nav--next" id="lightboxNext" aria-label="Next image">›</button>
    <div class="lightbox__inner">
        <img id="lightboxImage" src="" alt="">
        <div class="lightbox__meta">
            <p class="lightbox__caption" id="lightboxCaption"></p>
            <p class="lightbox__date" id="lightboxDate"></p>
            <p class="lightbox__location" id="lightboxLocation"></p>
        </div>
    </div>
  </div>
  <script src="/js/gallery-page.js"></script>
  
  {% set paginationPrevText = "Newer Images" %}
  {% set paginationNextText = "Older Images" %}

  {% include "partials/pagination.html" %}
  {% include "partials/page-footer.html" %}
{% endblock %}